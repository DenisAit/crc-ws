# Database
DATABASE_URL="postgresql://lasanta:password@localhost:5432/lasanta_db?schema=public"

# Discord OAuth
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"
DISCORD_REDIRECT_URI="http://localhost:3000/api/auth/discord/callback"

# Discord Bot (für Rollen-Synchronisation)
DISCORD_BOT_TOKEN="your_discord_bot_token"
DISCORD_GUILD_ID="your_discord_server_id"

# Discord Webhooks
DISCORD_WEBHOOK_URL="your_aufstellung_webhook_url_for_channel_1514604027776733200"
DISCORD_ABMELDUNG_WEBHOOK_URL="your_abmeldung_webhook_url_for_channel_1514604027776733201"
DISCORD_PARTNER_WEBHOOK_URL="your_partner_taxi_tafelrunde_webhook_url"

# Default Admin (Discord User-ID die beim Bootstrap automatisch ADMIN-Rechte bekommt)
ADMIN_DISCORD_ID="1040754827589865472"

# JWT
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-here"
JWT_REFRESH_EXPIRES_IN="7d"

# App Configuration
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"
API_BASE_URL="http://localhost:3000"

