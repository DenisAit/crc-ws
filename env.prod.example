# Production Environment Variables
# Kopiere diese Datei zu .env und fülle die Werte aus

# Database (MariaDB läuft als `db` Service in docker-compose.prod.yml)
# Prisma-Schema nutzt Provider `mysql`, daher mysql:// Connection-String
MARIADB_ROOT_PASSWORD="your-secure-root-password"
MARIADB_USER="lasanta"
MARIADB_PASSWORD="your-secure-database-password"
MARIADB_DATABASE="lasanta_db"
# DATABASE_URL muss MARIADB_USER/MARIADB_PASSWORD/MARIADB_DATABASE enthalten
# Hostname `db` löst nur innerhalb des Docker-Compose-Netzwerks auf
DATABASE_URL="mysql://lasanta:your-secure-database-password@db:3306/lasanta_db"

# JWT Secrets (VERWENDE STARK PASSWÖRTER!)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"

# Discord OAuth
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"
DISCORD_REDIRECT_URI="https://rdf-nc.de/api/auth/discord/callback"

# Discord Bot (für Rollen-Synchronisation)
DISCORD_BOT_TOKEN="your_discord_bot_token"
DISCORD_GUILD_ID="your_discord_server_id"

# Discord Webhooks
DISCORD_WEBHOOK_URL="your_aufstellung_webhook_url_for_channel_1514604027776733200"
DISCORD_ABMELDUNG_WEBHOOK_URL="your_abmeldung_webhook_url_for_channel_1514604027776733201"
DISCORD_PARTNER_WEBHOOK_URL="your_partner_taxi_tafelrunde_webhook_url"

# Default Admin (Discord User-ID die beim Bootstrap automatisch ADMIN-Rechte bekommt)
ADMIN_DISCORD_ID="1040754827589865472"

# URLs (für rdf-nc.de mit SSL)
FRONTEND_URL="https://rdf-nc.de"
API_BASE_URL="https://rdf-nc.de"

# Let's Encrypt (für ssl/init-letsencrypt.sh, wird beim Cert-Issue + Renewal verwendet)
LETSENCRYPT_EMAIL="admin@rdf-nc.de"
